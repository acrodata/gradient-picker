{
  "name": "gradient-picker",
  "version": "0.0.0-NOT-USED",
  "engines": {
    "yarn": ">=1.22.0 <2",
    "npm": "Please use Yarn instead of NPM to install dependencies"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve dev-app",
    "build": "ng build dev-app --base-href=/gradient-picker/",
    "watch": "ng build dev-app --watch --configuration development",
    "test": "ng test dev-app",
    "lint": "ng lint --fix && npm run lint:scss",
    "lint:ts": "eslint \"projects/**/*.ts\" --fix",
    "lint:scss": "stylelint \"projects/**/*.scss\" --fix",
    "build:lib": "ng build gradient-picker && cp README.md dist/gradient-picker",
    "publish": "npm run build:lib && cd dist/gradient-picker && npm publish",
    "deploy": "npm run build && ng deploy",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@acrodata/color-picker": "^1.4.0",
    "@acrodata/gradient-parser": "^1.1.0",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.21",
    "@angular/compiler": "^20.3.21",
    "@angular/core": "^20.3.21",
    "@angular/forms": "^20.3.21",
    "@angular/platform-browser": "^20.3.21",
    "@angular/router": "^20.3.21",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.26",
    "@angular/cli": "^20.3.26",
    "@angular/compiler-cli": "^20.3.21",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/jasmine": "~5.1.0",
    "angular-cli-ghpages": "^3.0.0",
    "angular-eslint": "^20.7.0",
    "eslint": "^9.13.0",
    "husky": "^9.1.6",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "^16.4.0",
    "ng-packagr": "^20.3.2",
    "prettier": "^3.8.0",
    "stylelint": "^16.10.0",
    "stylelint-config-recommended-scss": "^14.1.0",
    "stylelint-config-standard": "^36.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.12.0"
  }
}
